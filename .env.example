# Required for arbitrary natural-language conditions
ANTHROPIC_API_KEY=sk-ant-...
ALARM_MCP_MODEL=claude-3-5-haiku-latest

# Local alarm sound length (macOS)
ALARM_MCP_RING_SECONDS=20

# Bridge to the iOS/macOS Alarm app via Apple Shortcuts
# (name of a Shortcut you created in the Shortcuts app)
ALARM_MCP_SHORTCUT=Fire Alarm MCP

# Push to phone via ntfy.sh (install the ntfy app, subscribe to this topic)
ALARM_MCP_NTFY_TOPIC=

# Generic webhook (Slack, Discord, your own URL)
ALARM_MCP_WEBHOOK=

# Override the state directory (default: ~/.alarm-mcp)
ALARM_MCP_STATE_DIR=
